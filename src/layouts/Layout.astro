---
import "../styles/global.css";

import { Navbar } from "../components/navigation/Navbar.jsx";
import Footer from "../components/Footer.astro";

import { getCollection } from "astro:content";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const seoDataObject = {
  "@context": "https://schema.org",
  "@type": "Plumber",
  name: "WA Dash Plumbing & Gas",
  url: "https://wadash.com.au",
  telephone: "+61402246252",
  priceRange: "$$",
  areaServed: {
    "@type": "AdministrativeArea",
    name: "Perth, Western Australia",
  },
  image: [
    "https://wadash.com.au/logo.png",
    "https://wadash.com.au/hero.webp",
  ],
  address: {
    "@type": "PostalAddress",
    addressLocality: "Perth",
    addressRegion: "WA",
    addressCountry: "AU",
  },
  sameAs: [
    "https://www.facebook.com/wadashplumbingandgas",
    "https://www.instagram.com/wa_dash_plumbing_and_gas/",
    "https://www.linkedin.com/company/wa-dash-plumbing-and-gas/",
  ],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "07:00",
      closes: "16:00",
    },
  ],
};

const DEFAULT_DESCRIPTION = "Trusted Perth plumbers for emergency repairs, gas fitting, hot water systems and maintenance. Fast, friendly service across Perth. Call WA Dash Plumbing and Gas today.";
const { title, description = DEFAULT_DESCRIPTION, ogImage } = Astro.props;
const ogImageUrl = ogImage
  ? `https://wadash.com.au/${ogImage}`
  : "https://wadash.com.au/hero.webp";

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

const services = await getCollection("services");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="WA Dash Plumbing and Gas" />
    <meta property="og:logo" content="https://wadash.com.au/logo.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(seoDataObject)}
    />
  </head>
  <body>
    <Navbar client:load services={services} />
    <slot />
    <Footer/>
  </body>
</html>
