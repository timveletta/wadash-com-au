---
import Layout from "../layouts/Layout.astro";
import Contact from "../components/Contact.astro";

import { PhoneIcon } from "@heroicons/react/16/solid";
import Testimonials from "../components/Testimonials.astro";
---

<Layout title="About Us – WA Dash Plumbing & Gas">
  <main class="bg-gray-200">
    <!-- Hero -->
    <div class="relative bg-tertiary md:pb-48">
      <div
        class="md:py-12 flex justify-center items-center md:flex-row flex-col"
      >
        <div
          class="md:bg-white bg-gray-200 z-10 p-10 md:rounded-2xl max-w-2xl md:min-w-md lg:-mr-24 md:-mr-36 md:mb-0 md:w-auto w-full"
        >
          <h1 class="text-montserrat lg:text-5xl text-4xl">About</h1>
          <h2
            class="text-montserrat lg:text-5xl text-4xl text-primary font-extrabold"
          >
            WA Dash.
          </h2>
          <div class="flex gap-2 mt-8">
            <a
              class="px-6 py-3 font-bold bg-primary hover:bg-primary-dark rounded-full text-white flex"
              href="tel:+61402246252"
              ><PhoneIcon className="size-6 mr-2" /> 0402 246 252</a
            >
          </div>
        </div>

        <div class="md:max-w-3xl lg:-ml-24 md:-ml-36">
          <img
            src="/about-us.jpg"
            class="md:rounded-2xl object-cover aspect-3/2 h-150 w-auto"
          />
        </div>
      </div>
      <div
        class="hidden md:block absolute bottom-0 left-0 w-full overflow-hidden leading-none pointer-events-none"
      >
        <svg
          viewBox="0 0 1440 60"
          preserveAspectRatio="none"
          class="w-full h-64"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M0,40 C360,0 1080,80 1440,40 L1440,60 L0,60 Z"
            class="fill-gray-200"></path>
        </svg>
      </div>
    </div>

    <!-- Content -->
    <div class="py-12 px-4">
      <div class="container">
        <h1 class="text-4xl text-montserrat font-light text-tertiary mb-4">
          We are Perth-based, <div class="font-bold text-primary-dark">
            family-owned and operated
          </div>
        </h1>
        <div
          class="max-w-2xl flex flex-col gap-4 text-lg text-tertiary text-justify"
        >
          <p>
            Plumbing and gas services company proudly servicing Perth
            metropolitan area and regional Western Australia since 2019.
          </p><p>
            Backed by over 16 years of industry experience, we deliver
            professional, compliant, and reliable plumbing solutions across
            residential, commercial, government, education, and strata sectors.
          </p>
        </div>
      </div>
    </div>

    <div class="relative bg-gray-200 py-16 px-4">
      <div class="py-12 flex justify-center items-center md:flex-row flex-col">
        <div class="lg:-mr-12 md:-mr-18 z-10 hidden md:block shrink-0">
          <img
            src="/dash-christmas.jpg"
            class="rounded-2xl object-cover aspect-square h-100 w-100"
          />
        </div>

        <div
          class="bg-white py-16 lg:pl-36 md:pl-48 pl-10 pr-10 rounded-3xl max-w-3xl md:min-w-md lg:-ml-12 md:-ml-18 md:mb-0"
        >
          <h1 class="text-montserrat lg:text-5xl text-4xl">
            Why choose <span class="text-primary font-extrabold">WA Dash?</span>
          </h1>
          <div
            class="text-lg leading-relaxed text-secondary py-6 font-sans flex flex-col gap-4"
          >
            <p>
              Our licensed Perth plumbers and gas fitters specialise in
              preventative maintenance, emergency plumbing, renovations,
              compliance works, and long-term service contracts.
            </p>
            <p>
              We work closely with government agencies, facility managers,
              strata companies, and property managers to provide safe,
              cost-effective plumbing and gas services that meet Australian
              Standards, WHS requirements, and contractual obligations
              throughout WA.
            </p>
          </div>
          <div class="flex gap-2 mt-4">
            <a
              class="px-6 py-3 font-bold bg-primary hover:bg-primary-dark rounded-full text-white flex"
              href="tel:+61402246252"
              ><PhoneIcon className="size-6 mr-2" /> 0402 246 252</a
            >
          </div>
        </div>
      </div>
    </div>

    <Testimonials />
    <Contact />
  </main>
</Layout>
