---
import { PhoneIcon } from "@heroicons/react/16/solid";
---

<div class="relative bg-gray-200 py-16 px-4">
  <div class="py-12 flex justify-center items-center md:flex-row flex-col">
    <div class="lg:-mr-12 md:-mr-18 z-10 hidden md:block shrink-0">
      <img
        src="/hero.webp"
        alt="WA Dash Plumbing & Gas team"
        width="2048"
        height="1436"
        loading="lazy"
        class="rounded-2xl object-cover aspect-square h-100 w-100"
      />
    </div>

    <div
      class="bg-white py-16 lg:pl-36 md:pl-48 pl-10 pr-10 rounded-3xl max-w-3xl md:min-w-md lg:-ml-12 md:-ml-18 md:mb-0"
    >
      <h1 class="text-montserrat lg:text-5xl text-4xl">
        Why choose <span class="text-primary font-extrabold">WA Dash?</span>
      </h1>
      <div
        class="text-lg leading-relaxed text-secondary py-6 font-sans flex flex-col gap-4"
      >
        <p>
          Our licensed Perth plumbers and gas fitters specialise in preventative
          maintenance, emergency plumbing, renovations, compliance works, and
          long-term service contracts.
        </p>
        <p>
          We work closely with government agencies, facility managers, strata
          companies, and property managers to provide safe, cost-effective
          plumbing and gas services that meet Australian Standards, WHS
          requirements, and contractual obligations throughout WA.
        </p>
      </div>
      <div class="flex flex-wrap gap-2 mt-4">
        <a
          class="px-4 py-2 md:px-6 md:py-3 text-sm md:text-base font-bold bg-primary hover:bg-primary-dark rounded-full text-white flex items-center"
          href="tel:+61402246252"
          ><PhoneIcon className="size-5 mr-2" /> 0402 246 252</a
        >
        <a
          target="_blank"
          class="px-4 py-2 md:px-6 md:py-3 text-sm md:text-base font-bold bg-tertiary rounded-full text-white flex items-center"
          href="https://book.servicem8.com/request_booking?uuid=006d09d9-1dc2-4bd8-832e-5962ab602efb"
          >Book Now</a
        >
      </div>
    </div>
  </div>
</div>
