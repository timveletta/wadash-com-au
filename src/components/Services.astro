---
import { PhoneIcon } from "@heroicons/react/24/outline";
import ServiceSection from "./ServiceSection.astro";
---

<div class="lg:px-12 px-2 py-16 bg-white">
  <div class="container">
    <div class="flex flex-col md:flex-row gap-2 justify-between py-12">
      <div class="flex-1 flex flex-col gap-2">
        <h1 class="text-4xl text-montserrat text-tertiary">
          Our <span class="font-bold">services</span>
        </h1>
        <p class="text-lg text-tertiary">
          Our team delivers fast repairs, fixes, and reliable maintenance for
          homes and businesses to keep your pipes and drains flowing smoothly.
        </p>
      </div>
      <div class="flex-1 justify-end items-center flex gap-2">
        <a
          class="px-6 py-3 font-bold bg-primary hover:bg-primary-dark rounded-full text-white flex"
          href="tel:+61402246252"
          ><PhoneIcon className="size-6 mr-2" /> 0402 246 252</a
        >
      </div>
    </div>
    <div class="grid md:grid-cols-2 grid-cols-1 md:gap-8 gap-4">
      <ServiceSection
        title="Leaking Taps and Toilets"
        description="Sink taps and toilet installation, servicing and replacement."
        price="195"
        href="/services/leaking-taps-and-toilets"
        bullets={["Tap washer & cartridge replacement", "Toilet cistern repairs", "Mixer tap installation"]}
      >
        <img
          src="leaking-tap.webp"
          alt="Leaking tap repair Perth"
          class="object-cover h-full w-full md:aspect-2/3 aspect-square" loading="lazy"
        />
      </ServiceSection>
      <ServiceSection
        title="Hot Water Systems"
        description="Gas, electric and heat pump hot water systems."
        price="950"
        href="/services/hot-water-systems"
        bullets={["Supply & installation", "Same-day replacements available", "All major brands serviced"]}
      >
        <img
          src="hot-water-systems.webp"
          alt="Hot water system installation Perth"
          class="object-cover h-full w-full md:aspect-2/3 aspect-square" loading="lazy"
        />
      </ServiceSection>
      <ServiceSection
        title="Blocked Drains"
        description="Pipe inspections, unblocking and repairs."
        price="165"
        href="/services/blocked-drains"
        bullets={["CCTV pipe inspections", "High-pressure water jetting", "Root intrusion removal"]}
      >
        <img
          src="blocked-drain.webp"
          alt="Blocked drain clearing Perth"
          class="object-cover h-full w-full md:aspect-2/3 aspect-square" loading="lazy"
        />
      </ServiceSection>
      <ServiceSection
        title="Gas Works"
        description="Installation and maintenance of gas appliances and lines."
        price="225"
        href="/services/gas-works"
        bullets={["Gas appliance installation", "Leak detection & repair", "New gas point installation"]}
      >
        <img
          src="gas.jpg"
          alt="Gas fitting and installation Perth"
          class="object-cover h-full w-full md:aspect-2/3 aspect-square" loading="lazy"
        />
      </ServiceSection>
      <ServiceSection
        title="Water Filters"
        description="Clean, great-tasting water straight from your tap."
        price="515"
        href="/services/water-filters"
        bullets={["Under-sink & whole-house systems", "Filter cartridge replacements", "Water softener installation"]}
      >
        <img
          src="water-filters.webp"
          alt="Water filter installation Perth"
          class="object-cover h-full w-full md:aspect-2/3 aspect-square" loading="lazy"
        />
      </ServiceSection>
    </div>
  </div>
</div>
