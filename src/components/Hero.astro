---
import { PhoneIcon } from "@heroicons/react/16/solid";
---

<div class="relative bg-gray-200 md:pb-16 lg:pb-24">
  <div
    class="md:py-12 pt-12 flex justify-center items-center md:flex-row flex-col"
  >
    <div
      class="bg-white z-10 p-10 rounded-2xl max-w-2xl md:min-w-md lg:-mr-12 md:-mr-18 md:mb-0 -mb-56"
    >
      <h1 class="text-montserrat lg:text-5xl text-4xl">Plumbing and Gas</h1>
      <h2
        class="text-montserrat lg:text-5xl text-4xl text-primary font-extrabold"
      >
        in a Dash.
      </h2>
      <p class="text-lg leading-relaxed text-secondary py-6 font-sans">
        Locally owned and operated in WA.<br />
        Got a plumbing or gas emergency? <br />
        We’re available 24/7. Call us now!
      </p>
      <div class="flex gap-2 mt-4">
        <a
          class="px-6 py-3 font-bold bg-primary hover:bg-primary-dark rounded-full text-white flex"
          href="tel:+61402246252"
          ><PhoneIcon className="size-6 mr-2" /> 0402 246 252</a
        >
      </div>
    </div>

    <div class="md:max-w-3xl lg:-ml-12 md:-ml-18">
      <img
        src="/hero.webp"
        alt="WA Dash plumber working on a pipe in a Perth home"
        width="2016"
        height="1512"
        class="md:rounded-2xl object-cover aspect-3/2 w-auto h-120"
      />
    </div>
  </div>
</div>

